local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LP = Players.LocalPlayer
local roles

-- ПЕРЕМЕННЫЕ
local MurdererName = ""
local SheriffName = ""
local HeroName = ""
local MyRole = "Неизвестно"
local GunCollected = false
local SheriffWasAlive = true
local ESPEnabled = true
local AutoGunEnabled = true

-- ==================== ФУНКЦИИ ====================

function IsAlive(Player)
    if not Player then return false end
    for i, v in pairs(roles) do
        if Player.Name == i then
            if not v.Killed and not v.Dead then
                return true
            else
                return false
            end
        end
    end
    return false
end

function FindGun()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "Gun" or v.Name == "Pistol" or v.Name == "Revolver" or v.Name == "SheriffGun" then
            if v:IsA("Tool") or v:IsA("BasePart") or v:IsA("Model") then
                if v.Parent and v.Parent ~= LP.Character and v.Parent ~= workspace then
                    return v
                end
            end
        end
        if v.Name == "Handle" and v.Parent then
            local pn = v.Parent.Name
            if pn == "Gun" or pn == "Pistol" or pn == "Revolver" or pn == "SheriffGun" then
                if v.Parent.Parent and v.Parent.Parent ~= LP.Character then
                    return v.Parent
                end
            end
        end
    end
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name:find("Gun") or v.Name:find("Pistol") or v.Name:find("Revolver")) then
            if v.Parent and v.Parent ~= LP.Character then
                return v
            end
        end
    end
    return nil
end

function GetGunPosition(gun)
    if not gun then return nil end
    if gun:IsA("BasePart") then return gun.Position end
    local handle = gun:FindFirstChild("Handle")
    if handle and handle:IsA("BasePart") then return handle.Position end
    local pp = gun:FindFirstChildWhichIsA("BasePart")
    if pp then return pp.Position end
    pcall(function()
        return gun:GetPivot().Position
    end)
    return nil
end

function HasGun()
    if not LP.Character then return false end
    for _, v in pairs(LP.Character:GetChildren()) do
        if v:IsA("Tool") and (v.Name:lower():find("gun") or v.Name:lower():find("pistol") or v.Name:lower():find("revolver")) then
            return true
        end
    end
    if LP.Backpack then
        for _, v in pairs(LP.Backpack:GetChildren()) do
            if v:IsA("Tool") and (v.Name:lower():find("gun") or v.Name:lower():find("pistol") or v.Name:lower():find("revolver")) then
                return true
            end
        end
    end
    return false
end

function SmoothTeleport(targetPos)
    if not LP.Character then return end
    local hrp = LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local goal = {CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))}
    local tween = TweenService:Create(hrp, tweenInfo, goal)
    tween:Play()
    tween.Completed:Wait()
end

function TeleportToPosition(pos)
    if not LP.Character then return end
    local hrp = LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
end

