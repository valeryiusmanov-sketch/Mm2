            HeroName = ""
            
            for i, v in pairs(roles) do
                if v.Role == "Murderer" then
                    MurdererName = i
                elseif v.Role == "Sheriff" then
                    SheriffName = i
                elseif v.Role == "Hero" then
                    HeroName = i
                end
                
                if i == LP.Name then
                    MyRole = v.Role or "Неизвестно"
                end
            end
        end)
    end
    
    if Sheriff and IsAlive(Sheriff) then
        GunCollected = false
        SheriffWasAlive = true
    end
    
    local murderInfo = MurdererName ~= "" and Players[MurdererName] and IsAlive(Players[MurdererName]) and MurdererName or "Нет"
    local sheriffInfo = SheriffName ~= "" and Players[SheriffName] and IsAlive(Players[SheriffName]) and SheriffName or "Нет"
    InfoLabel.Text = "🎯 Роль: " .. tostring(MyRole) .. "\n🔪 Убийца: " .. murderInfo .. " | ⭐ Шериф: " .. sheriffInfo
    
    CreateHighlight()
    UpdateHighlights()
    
    AutoGunTP()
end)

