        ESPBtn.Text = "👁 ESP ВЫКЛ"
        StatusLabel.Text = "👁 ESP выключен"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end)

GunTpBtn.MouseButton1Click:Connect(function()
    StatusLabel.Text = "🔫 Ищу пистолет..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    
    local gun = FindGun()
    if gun then
        local gunPos = GetGunPosition(gun)
        if gunPos then
            local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            local oldPos = hrp and hrp.Position
            
            pcall(function()
                SmoothTeleport(gunPos)
            end)
            
            StatusLabel.Text = "🔫 ТП к пистолету!"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
            
            task.wait(1.2)
            
            if HasGun() then
                GunCollected = true
                StatusLabel.Text = "✅ Пистолет у тебя!"
                StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
            end
            
            if oldPos then
                task.wait(0.3)
                pcall(function()
                    SmoothTeleport(oldPos)
                end)
                StatusLabel.Text = "🏠 Вернулся обратно"
                StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
            end
        end
    else
        StatusLabel.Text = "❌ Пистолет не найден"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end)

