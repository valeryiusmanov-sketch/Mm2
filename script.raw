end)

-- ==================== ESP ХАЙЛАЙТЫ ====================

function CreateHighlight()
    for i, v in pairs(Players:GetChildren()) do
        if v ~= LP and v.Character then
            if not v.Character:FindFirstChild("SWILL_Highlight") then
                local hl = Instance.new("Highlight")
                hl.Name = "SWILL_Highlight"
                hl.Parent = v.Character
            end
        end
    end
end

function UpdateHighlights()
    for _, v in pairs(Players:GetChildren()) do
        if v ~= LP and v.Character then
            local hl = v.Character:FindFirstChild("SWILL_Highlight")
            if hl then
                hl.Enabled = ESPEnabled
                if v.Name == MurdererName and IsAlive(v) then
                    hl.FillColor = Color3.fromRGB(225, 0, 0)
                    hl.OutlineColor = Color3.fromRGB(255, 100, 100)
                elseif v.Name == SheriffName and IsAlive(v) then
                    hl.FillColor = Color3.fromRGB(0, 0, 225)
                    hl.OutlineColor = Color3.fromRGB(100, 150, 255)
                elseif v.Name == HeroName and IsAlive(v) then
                    hl.FillColor = Color3.fromRGB(255, 250, 0)
                    hl.OutlineColor = Color3.fromRGB(255, 255, 150)
                else
                    hl.FillColor = Color3.fromRGB(0, 225, 0)
                    hl.OutlineColor = Color3.fromRGB(100, 255, 100)
                end
            end
        end
    end
end

-- ==================== АВТО ТП НА ПИСТОЛЕТ ====================

function AutoGunTP()
    if not AutoGunEnabled then return end
    if MyRole ~= "Hero" and MyRole ~= "Герой" then return end
    if not LP.Character then return end
    if not IsAlive(LP) then return end
    if GunCollected then return end
    if HasGun() then
        GunCollected = true
        StatusLabel.Text = "✅ Пистолет уже у тебя!"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        return
    end
    
    local sheriffPlayer = Players:FindFirstChild(SheriffName)
    if not sheriffPlayer then return end
    if IsAlive(sheriffPlayer) then
        SheriffWasAlive = true
        return
    end
    
    if SheriffWasAlive and not IsAlive(sheriffPlayer) then
        SheriffWasAlive = false
        StatusLabel.Text = "💀 Шериф убит! Ищу пистолет..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        
        task.wait(0.5)
        
        local gun = FindGun()
        if gun and not GunCollected and not HasGun() then
            local gunPos = GetGunPosition(gun)
            if gunPos and LP.Character then
                local hrp = LP.Character:FindFirstChild("HumanoidRootPart")
                local oldPos = hrp and hrp.Position
                
                StatusLabel.Text = "🔫 ТП к пистолету!"
                StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
                
                pcall(function()
                    SmoothTeleport(gunPos)
                end)
                
                task.wait(1.2)
                
                if HasGun() then
                    GunCollected = true
                    StatusLabel.Text = "✅ Пистолет подобрал!"
                    StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
                else
                    gun = FindGun()
                    if gun and not HasGun() then
                        gunPos = GetGunPosition(gun)
                        if gunPos then
                            pcall(function()
                                TeleportToPosition(gunPos)
                            end)
                            task.wait(0.8)
                            if HasGun() then
                                GunCollected = true
                                StatusLabel.Text = "✅ Пистолет подобрал!"
                                StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
                            end
                        end
                    end
                end
                
                if oldPos then
                    task.wait(0.3)
                    pcall(function()
                        SmoothTeleport(oldPos)
                    end)
                    StatusLabel.Text = "🏠 Вернулся. Пистолет у тебя!"
                    StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
                end
            end
        end
    end
end

